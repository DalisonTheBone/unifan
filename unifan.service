[Unit]
Description=Universal Fancontrol For Arch Linux
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/node /usr/bin/unifan-bin/unifan-daemon.js
Restart=always
RestartSec=3
User=root

# Optional hardening
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
